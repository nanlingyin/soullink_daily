DATABASE_URL="file:./dev.db"

# 默认 true：使用本地 fallback，不调用真实模型，便于先跑通项目闭环。
AI_MOCK_MODE="true"

# OpenAI-compatible chat completions，可选。
CHAT_API_BASE_URL="https://api.openai.com/v1"
CHAT_API_KEY=""
CHAT_MODEL="gpt-4o-mini"

# OpenAI-compatible image generations，可选。
IMAGE_API_BASE_URL="https://api.openai.com/v1"
IMAGE_API_KEY=""
IMAGE_MODEL="gpt-image-1"
